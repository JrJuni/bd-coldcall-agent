# ============================================================
# bd-coldcall-agent — copy this file to `.env` and fill in values
# Non-secret defaults: config/settings.yaml
# User data (targets, Notion IDs): config/targets.yaml
# ============================================================

# --- API keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
BRAVE_SEARCH_API_KEY=BSA...

# --- API keys (optional) ---
# Only needed if you index Notion pages/databases via RAG (read-only path).
NOTION_TOKEN=secret_...

# --- Phase 13A — Notion write integrations (BDINT workspaces) ---
# Required for MCP tools that write to Notion (e.g. answer_rfp_question).
# Two separate integrations: one per Notion workspace.
NOTION_TEAMSPACE_TOKEN=secret_...
NOTION_PUBLICSPACE_TOKEN=secret_...

# --- Phase 13B — Database URL ---
# SQLAlchemy URL for the app DB. Defaults to local SQLite if unset.
# SQLite (dev/default):  sqlite:///data/app.db
# Postgres (Neon, etc.):
#   postgresql+psycopg://<user>:<pass>@<host>/<db>?sslmode=require
# Neon's pooled URL works; pick the "Connection pooling" URL in the
# Neon dashboard for production-style traffic. After switching, run:
#   alembic upgrade head
#   python scripts/migrate_sqlite_to_postgres.py --source sqlite:///data/app.db \
#       --target "$DATABASE_URL" --apply
# (see docs/phase13.md for the full cutover procedure).
DATABASE_URL=sqlite:///data/app.db
