# ============================================================
# bd-coldcall-agent — copy this file to `.env` and fill in values
# Non-secret defaults: config/settings.yaml
# User data (targets, Notion IDs): config/targets.yaml
# ============================================================

# --- API keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
BRAVE_SEARCH_API_KEY=BSA...

# --- API keys (optional) ---
# Only needed if you index Notion pages/databases via RAG
NOTION_TOKEN=secret_...
