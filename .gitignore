# Web UI (Phase 7 — Next.js)
web/node_modules/
web/.next/
web/out/
# Guard against uvicorn / indexer being launched from web/ cwd —
# `data/app.db` is a relative path and would land here as `web/data/app.db`
web/data/

# Model caches
.cache/
# Root-level HF / Exaone weight dumps — NOT src/api/models/ which is the
# SQLAlchemy ORM package (anchor to root with leading slash so the rule
# only matches `./models/` not arbitrary `models/` further down the tree).
/models/
.huggingface/

